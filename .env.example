# Database — pooler URL for Vercel Functions, transaction-mode (port 6543)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres

# Direct URL — used by drizzle-kit for migrations only
DIRECT_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase public keys (used by browser code via @supabase/ssr — Phase 2)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=

# Public site origin — used by signUp emailRedirectTo and OAuth callback redirect.
# In production this is the Vercel URL; locally it defaults to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to 'true' to enable the Google OAuth button on /sign-in and /sign-up.
# Requires configuring a Google OAuth client in Supabase Auth → Providers → Google first.
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true

# Local Supabase emulator (pnpm supabase start) — requires Docker
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# DIRECT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<from `supabase status` output>
